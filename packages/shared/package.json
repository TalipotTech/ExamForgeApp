{
  "name": "@examforge/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./db/schema": {
      "types": "./src/db/schema/index.ts",
      "import": "./dist/db/schema/index.js",
      "default": "./dist/db/schema/index.js"
    },
    "./validators": {
      "types": "./src/validators/index.ts",
      "import": "./dist/validators/index.js",
      "default": "./dist/validators/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "import": "./dist/constants/index.js",
      "default": "./dist/constants/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/fix-esm-imports.mjs",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.11.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
