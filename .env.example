# ──────── ExamForge Environment Variables ────────
# Copy to .env.local for development. NEVER commit .env files with real values.
# Production: use AWS Secrets Manager via CDK.

# ──────── APP ────────
NODE_ENV=development
APP_URL=http://localhost:3100
API_URL=http://localhost:4100

# ──────── DATABASE ────────
DATABASE_URL=postgresql://examforge:examforge_dev@localhost:5432/examforge_dev
# For pgvector: ensure CREATE EXTENSION vector; is run

# ──────── REDIS ────────
REDIS_URL=redis://localhost:6379

# ──────── AUTH ────────
NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=your-dev-secret-change-this-in-production
AUTH_SECRET=your-dev-secret-change-this-in-production
# Google OAuth (optional for dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# MSG91 OTP (India SMS)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=EXMFRG
# Twilio SMS (alternative to MSG91)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Gmail SMTP (primary email provider)
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=ExamForge <noreply@examforge.com>
# Resend Email (alternative — uncomment in email-service.ts to use)
# RESEND_API_KEY=

# ──────── AI PROVIDERS ────────
# Claude (Anthropic) — Primary
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OpenAI — Structured output + embeddings
OPENAI_API_KEY=sk-xxxxx
# Google Gemini — Video processing + long context
GOOGLE_GENERATIVE_AI_API_KEY=xxxxx
# Mistral — Bulk generation (cheapest)
MISTRAL_API_KEY=xxxxx
# Perplexity — Web search for current affairs
PERPLEXITY_API_KEY=pplx-xxxxx
# OpenRouter — Fallback gateway (optional)
OPENROUTER_API_KEY=

# ──────── AI COST CONTROLS ────────
AI_MONTHLY_BUDGET_USD=100
AI_CACHE_TTL_SECONDS=86400
AI_MAX_RETRIES=3
AI_RATE_LIMIT_PER_USER_PER_MIN=10

# ──────── PAYMENTS ────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ──────── AWS (local dev uses localstack or direct) ────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=examforge-uploads-dev
CLOUDFRONT_DOMAIN=

# ──────── SCRAPING ────────
SCRAPER_CONCURRENCY=3
SCRAPER_RATE_LIMIT_MS=2000
PROXY_URL=
# BrightData (optional)
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
BRIGHTDATA_HOST=

# ──────── INTEGRATIONS — 100ms (Live Sessions, Option C: embedded video) ────────
# Setup: https://dashboard.100ms.live → create App → copy keys.
# Template must define `creator` and `student` roles. Recording template
# is optional — set HMS_RECORDING_TEMPLATE_ID if you want a separate
# template for sessions where recording is enabled.
HMS_APP_ACCESS_KEY=
HMS_APP_SECRET=
HMS_TEMPLATE_ID=
HMS_RECORDING_TEMPLATE_ID=
HMS_WEBHOOK_PASSCODE=
HMS_API_BASE=https://api.100ms.live/v2

# ──────── INTEGRATIONS — ZOOM (Live Sessions, Option B) ────────
# Marketplace OAuth app (User-managed). Setup steps in
# docs/features/LIVE_SESSIONS_OPTION_B_ZOOM.md "Operator setup".
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:3100/api/integrations/zoom/callback
ZOOM_WEBHOOK_SECRET_TOKEN=
# AES-256-GCM key for encrypting OAuth tokens at rest. Generate with:
#   openssl rand -base64 32
# In prod, source from AWS Secrets Manager / KMS.
ZOOM_TOKEN_ENCRYPTION_KEY=

# ──────── AI IMAGE GENERATION ────────
# Multi-model routing: OpenAI GPT Image / Google Imagen 4 / Ideogram 3.0.
# See docs/features/ai-image-gen/AI_IMAGE_GENERATION.md
# OPENAI_API_KEY (above) is reused for GPT Image — no new key needed.
GOOGLE_AI_API_KEY=                          # for Imagen 4 (Google AI Studio)
IDEOGRAM_API_KEY=                           # for Ideogram 3.0 (text-heavy images)

# Storage driver for generated images.
#   local (default) → filesystem at IMAGE_STORAGE_DIR, served at /api/images/*
#   s3              → S3 / S3-compatible (e.g. Cloudflare R2) via IMAGE_S3_BUCKET
# Leave unset to auto-pick: s3 if IMAGE_S3_BUCKET is set, else local.
IMAGE_STORAGE_DRIVER=local
# Local driver: where image files live. On Railway, set to a mounted Volume
# path (e.g. /data/images) so files survive redeploys. Default: <cwd>/storage/images
IMAGE_STORAGE_DIR=
# Optional: absolute public origin of the API (e.g. https://api.example.com).
# When set, stored image URLs are absolute; otherwise relative (/api/images/...)
# and the web app prefixes them with NEXT_PUBLIC_API_URL.
IMAGE_PUBLIC_BASE_URL=
# S3 driver (switchable later — keep blank to use local):
IMAGE_S3_BUCKET=                            # e.g. examforge-images (AWS) or an R2 bucket
IMAGE_CLOUDFRONT_DOMAIN=
IMAGE_DEFAULT_QUALITY=standard              # standard | hd
IMAGE_MONTHLY_BUDGET_USD=100
# Set to "true" to let the tutorial agent auto-generate diagrams (off by default — costs budget)
TUTORIAL_DIAGRAM_GENERATION=false
# Upper bound (ms) for the context-brief LLM step before it falls back to a
# deterministic prompt. Keeps the synchronous single-topic request snappy.
IMAGE_BRIEF_TIMEOUT_MS=12000

# ──────── TOPIC SEARCH + LEARNING PATH ────────
# Cache window for the AI self-assessment per (user, exam, subject).
LEARNING_PATH_TTL_HOURS=24
# Set false to skip the Tier-2 AI scope classifier (heuristic-only guardrail).
SEARCH_SCOPE_AI_ENABLED=true
# Demand-driven content scheduler (daily sweep → enqueues existing generators).
AUTO_CONTENT_ENABLED=true
# Optional tuning for the demand sweep:
# AUTO_CONTENT_DAILY_LIMIT=10
# AUTO_CONTENT_MIN_SCORE=2
# AUTO_CONTENT_QUESTIONS_PER_NODE=10
# Pin the system actor for generated content (defaults to first admin user).
# AUTO_CONTENT_SYSTEM_USER_ID=

# ──────── MONITORING ────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=http://localhost:8000
